<!-- JOINTS -->
<joint name="joint1" type="revolute">
  <parent link="base_link"/>
  <child link="link1"/>
  <axis xyz="0 0 1"/>
  <limit lower="0" upper="1.57" effort="10" velocity="1.0"/>
</joint>
