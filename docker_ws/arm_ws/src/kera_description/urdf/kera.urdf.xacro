<?xml version="1.0"?>
<robot name="my_robot_arm">

  <!-- ===================== -->
  <!-- BASE LINK (YOUR BASE) -->
  <!-- ===================== -->
  <link name="base_link">
  <visual>
      <origin xyz="-0.082 -0.082 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://kera_description/meshes/base.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  <inertial>
    <!-- Center of mass from SolidWorks (converted mm -> m) -->
    <origin xyz="0 0 0.094" rpy="0 0 0"/>

    <!-- Mass converted grams -> kg -->
    <mass value="4.28"/>
    <!-- Inertia converted (grams*mm^2 -> kg*m^2) -->
    <inertia 
      ixx="0.01"
      iyy="0.01"
      izz="0.01"
      ixy="0.0"
      ixz="0.0"
      iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.01"/>
        <geometry>
          <sphere radius="0.01"/>
        </geometry>
        <material name="red"/>
    </visual>
    <!-- <collision>
      <origin xyz="-0.082 -0.082 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="base.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision> -->
  </link>
  <link name="link1">
  <visual>
    <geometry>
    <mesh filename="package://kera_description/meshes/shoulder_joint.STL" scale="0.001 0.001 0.001"/>
    </geometry>
    <origin xyz="-0.0441 0.079 0.1525" rpy="1.57 0 0"/>
    <material name="blue"/>
  </visual>
  <inertial>
    <!-- Center of mass from SolidWorks (converted mm -> m) -->
    <origin xyz="0.01 -0.0013 0.252" rpy="0 0 0"/>
    <mass value="4.11"/>
      <!-- Inertia converted (grams*mm^2 -> kg*m^2) -->
      <inertia
        ixx="0.01"
        iyy="0.01"
        izz="0.01"
        ixy="0.0"
        ixz="0.0"
        iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0.01 -0.0013 0.252"/>
        <geometry>
          <sphere radius="0.01"/>
        </geometry>
        <material name="red"/>
    </visual>
</link>
